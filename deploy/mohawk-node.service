[Unit]
Description=SMIP-MWP Mohawk Node
After=network.target

[Service]
Type=simple
User=root
Group=root
Environment=GOMAXPROCS=0
ExecStart=/usr/local/bin/mohawk-node --iface=eth0 --metrics-addr=:9090 -tags=withafxdp
Restart=on-failure
RestartSec=5s
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
