# Dockerfile for SMIP-MWP Performance Testing
FROM golang:1.25-bookworm AS builder

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y \
    libbpf-dev \
    clang \
    llvm \
    libelf-dev \
    iproute2 \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Copy dependency files first for caching
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Build main binary
RUN go build -o mohawk-node ./cmd/mohawk-node

# Build test binaries
RUN go test -c ./... -output=/app/test-binaries/ || true

FROM debian:bookworm-slim AS runner

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    libbpf-dev \
    clang \
    llvm \
    libelf-dev \
    iproute2 \
    ca-certificates \
    curl \
    procps \
    sysstat \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy binary and test binaries from builder
COPY --from=builder /app/mohawk-node ./mohawk-node
COPY --from=builder /app/test-binaries/ ./test-binaries/

# Copy benchmark script
COPY scripts/bench.sh ./scripts/
RUN chmod +x ./scripts/*.sh

# Copy performance analysis scripts
COPY --from=builder /app/internal ./internal
COPY --from=builder /cmd ./cmd

WORKDIR /app

# Install profiling tools
RUN go install github.com/google/pprof/cmd/pprof@latest

# Create test scripts directory
RUN mkdir -p /app/scripts/performance

# Copy additional performance scripts
COPY scripts/performance/ ./scripts/performance/

ENTRYPOINT ["/app/mohawk-node"]
CMD ["run"]
